{
  "manifest_version": 3,
  "name": "星火篝火番茄钟",
  "short_name": "Campfire Pomodoro",
  "description": "Outer Wilds 风格篝火新标签页，沉浸式时钟与经典番茄钟专注工具。",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
